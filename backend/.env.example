# =============================================================================
# NexusLLM environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the keys you actually have. Any provider
# whose key is left blank simply has zero usable keys and is skipped by the
# router at runtime (the config still loads fine).
#
#   cp .env.example .env
# =============================================================================

# --- NexusLLM server auth ----------------------------------------------------
# Required to call /admin/* endpoints (sent as `Authorization: Bearer <key>`).
NEXUS_ADMIN_KEY=change-me-admin-key
# Optional: if set, /v1/* proxy endpoints require this bearer token. Leave
# blank to expose the proxy without auth (local use only).
NEXUS_PROXY_KEY=

# --- Fully free providers (API key required) ---------------------------------
GOOGLE_AI_KEY=
GROQ_KEY_1=
GROQ_KEY_2=
CEREBRAS_KEY=
NVIDIA_KEY=
MISTRAL_KEY=
OPENROUTER_KEY=
GITHUB_MODELS_TOKEN=
COHERE_KEY=
# Cloudflare Workers AI: account id is baked into the base_url, plus an API token.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_KEY=
# Hugging Face Router (router.huggingface.co).
HUGGINGFACE_KEY=
# Z.AI / Zhipu GLM (GLM-4.5-Flash, GLM-4.6V-Flash free tier).
ZAI_KEY=
# Ollama Cloud (ollama.com).
OLLAMA_KEY=

# --- Free-key providers (key required, but free to obtain) -------------------
OPENCODE_ZEN_KEY=
KILO_KEY=
# LLM7 — free token from token.llm7.io unlocks all models.
LLM7_KEY=

# --- No API key required (these work with no key) ----------------------------
# OVHcloud AI Endpoints — free tier works WITHOUT a key. Set a key only for
# higher rate limits.
OVH_AI_KEY=
# Pollinations AI needs no key at all (no variable required).

# --- Firebase (Google sign-in / per-account multi-tenant workspaces) ---------
# Set this to your Firebase project id to enable Google login + per-account
# isolated keys. Leave blank to keep NexusLLM single-admin (admin key only).
# The backend verifies Firebase ID tokens against Google's public certs — no
# service-account JSON required, just the project id.
FIREBASE_PROJECT_ID=
