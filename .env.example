# =============================================================================
# NexusLLM root environment (used by docker compose via env_file: .env)
# Copy to .env and fill in the keys you have:  cp .env.example .env
# =============================================================================

# --- NexusLLM server auth ----------------------------------------------------
NEXUS_ADMIN_KEY=change-me-admin-key
NEXUS_PROXY_KEY=

# --- Fully free providers (API key required) ---------------------------------
GOOGLE_AI_KEY=
GROQ_KEY_1=
GROQ_KEY_2=
CEREBRAS_KEY=
NVIDIA_KEY=
MISTRAL_KEY=
OPENROUTER_KEY=
GITHUB_MODELS_TOKEN=
COHERE_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_KEY=
HUGGINGFACE_KEY=
ZAI_KEY=
OLLAMA_KEY=

# --- Free-key providers (key required, but free to obtain) -------------------
OPENCODE_ZEN_KEY=
KILO_KEY=

# --- No API key required -----------------------------------------------------
OVH_AI_KEY=
LLM7_KEY=
# Pollinations AI needs no key at all.
